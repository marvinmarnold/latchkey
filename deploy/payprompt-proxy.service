[Unit]
Description=Payprompt Proxy
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/payprompt
ExecStart=/root/.bun/bin/bun run packages/proxy/src/index.ts
EnvironmentFile=/root/payprompt/packages/proxy/.env
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
