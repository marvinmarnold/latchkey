PORT=3000
DB_PATH=./latchkey.db
BASE_RPC_URL=https://sepolia.base.org
NODE_ENV=development
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Phase 1 legacy balance contract (vault model). Leave blank — superseded by pull-payment below.
BALANCE_CONTRACT_ADDRESS=
# For tests: the caller wallet that approves USDC allowance and gets pulled from
TEST_PRIVATE_KEY=

# Phase 2 — pull-payment billing (Base Sepolia)
# Leave BILLING_CONTRACT_ADDRESS blank for Phase 1 mock mode (no allowance gate, no pulls).
# When set, the proxy enforces the allowance gate and the pull worker runs.
BILLING_CONTRACT_ADDRESS=
# Operator/signer wallet that calls pull() — MUST equal the contract's `proxy` constructor arg.
PROXY_PRIVATE_KEY=
# USDC token (Base Sepolia): 0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Token atomic-unit decimals (USDC = 6). Used to convert dollars → atomic units at pull time.
USDC_DECIMALS=6
# Accrued-debt threshold (USD) that triggers an on-chain pull.
PULL_THRESHOLD_USD=0.10

# Phase 5 — Solana rail
# Devnet USDC mint: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU  Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
SOLANA_RPC_URL=https://api.devnet.solana.com
# Test Solana keypair (ed25519). SOLANA_TEST_SECRET_KEY is the 32-byte seed, base58-encoded.
# The proxy verifies Solana bearer tokens — it does NOT need the secret key at runtime.
# This key is used by callers and E2E tests to generate signed bearer tokens.
# To generate a fresh keypair: run `solana-keygen new` and note the pubkey + seed phrase.
# The values below are the deterministic all-0x2a test seed used in unit tests — replace for real use.
SOLANA_TEST_SECRET_KEY=3qbR1eZRqXUWroWKKYhbDmR3FfqTHfqSU8zZSxtANzYh
SOLANA_TEST_PUBLIC_KEY=2iXtA8oeZqUU5pofxK971TCEvFGfems2AcDRaZHKD2pQ

# Deploy
DEPLOY_HOST=
DEPLOY_USER=root
DEPLOY_PASSWORD=
CLOUDFLARE_API_TOKEN=
