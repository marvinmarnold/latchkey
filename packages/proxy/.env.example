# =============================================================================
# Latchkey Proxy — single source of truth for all config and secrets
# Copy to .env and fill in values. .env is gitignored — never commit it.
# =============================================================================

# --- Server ------------------------------------------------------------------
PORT=3000
DB_PATH=./latchkey.db
NODE_ENV=development

# --- Provider API keys (seeded into listings at startup) ---------------------
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# --- EVM / Base Sepolia ------------------------------------------------------
BASE_RPC_URL=https://sepolia.base.org
# USDC on Base Sepolia. Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_DECIMALS=6

# --- Billing contract --------------------------------------------------------
# Deployed LatchkeyBilling address. Leave blank → Phase 1 mock mode (no pulls, no gate).
BILLING_CONTRACT_ADDRESS=
# Proxy operator keypair — calls pull() and receives 99% of each settlement.
# MUST match the `proxy` constructor arg used when deploying BILLING_CONTRACT_ADDRESS.
# NEVER commit this value. Address is derived: viem privateKeyToAccount(PROXY_PRIVATE_KEY).address
PROXY_PRIVATE_KEY=
# Protocol treasury — receives 1% fee. Baked into contract at deploy time.
# Currently same address as proxy wallet. Set separately before mainnet.
TREASURY_ADDRESS=

# --- Pull-payment thresholds -------------------------------------------------
# Accrued-debt level (USD) that triggers an on-chain pull.
# $0.01 for testing (frequent settlement). Raise for production to batch payments.
# Canonical default and derived atomics live in src/config.ts.
PULL_THRESHOLD_USD=0.01
# Minimum Caller Deposit (USD) enforced by the billing contract.
MIN_CALLER_DEPOSIT_USD=1

# --- Test / E2E wallets -------------------------------------------------------
# EVM test wallet — used by E2E tests to generate bearer tokens and approve allowances.
# Never hardcode this in source files; always read via process.env.TEST_PRIVATE_KEY.
TEST_PRIVATE_KEY=

# --- Legacy (Phase 1 vault model — superseded by pull-payment) ---------------
BALANCE_CONTRACT_ADDRESS=

# --- Solana rail (Phase 5) ---------------------------------------------------
# USDC mint. Devnet: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
#            Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
SOLANA_RPC_URL=https://api.devnet.solana.com
# Set to true ONLY when the Solana billing program is deployed and tested.
# Default (unset/false) = mock mode: Solana callers pay nothing.
SOLANA_BILLING_ENABLED=
# Caller-side test keypair for generating Solana bearer tokens in E2E tests.
# The proxy only verifies tokens — it never needs the secret key at runtime.
SOLANA_TEST_SECRET_KEY=
SOLANA_TEST_PUBLIC_KEY=

# --- Indexer (Phase 2 Ponder) ------------------------------------------------
INDEXER_RPC_URL=
INDEXER_START_BLOCK=

# --- Deploy / infrastructure -------------------------------------------------
DEPLOY_HOST=
DEPLOY_USER=root
DEPLOY_PASSWORD=
CLOUDFLARE_API_TOKEN=
