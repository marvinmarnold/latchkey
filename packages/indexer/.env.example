# Set after deploying LatchkeyBilling to Base Sepolia
BILLING_CONTRACT_ADDRESS=
# Set to deployment block to avoid scanning from genesis
INDEXER_START_BLOCK=
# Alchemy or other RPC with websockets for realtime indexing
# Public sepolia.base.org rate-limits; use Alchemy free tier for reliable realtime
INDEXER_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
